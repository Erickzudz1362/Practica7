FROM python:3.12-slim
WORKDIR /app
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
COPY common ./common
COPY inventory-service ./inventory-service
ENV PYTHONPATH=/app
EXPOSE 8003
CMD ["uvicorn", "main:app", "--app-dir", "inventory-service", "--host", "0.0.0.0", "--port", "8003"]
